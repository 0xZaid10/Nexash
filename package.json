{
  "name": "nexash-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "start": "node --env-file=.env --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "smoke-test": "node --env-file=.env --import tsx scripts/smokeTest.ts",
    "hsp-round-trip": "node --env-file=.env --import tsx scripts/hspFullRoundTrip.ts",
    "seed-attestation": "node --env-file=.env --import tsx scripts/seedAttestation.ts"
  },
  "dependencies": {
    "express": "^5.0.0",
    "viem": "^2.21.0",
    "better-sqlite3": "^11.3.0",
    "zod": "^3.23.0",
    "dotenv": "^16.4.0",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.0",
    "@types/better-sqlite3": "^7.6.0"
  }
}
